# -----------------------------------------------------------------------------
# Enterprise RFP Agent - Environment Variables
# -----------------------------------------------------------------------------
# Rename this file to .env and place it in the /backend directory.

# OpenAI (Required for LLM generation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Pinecone (Required if using external vector store)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=rfp-knowledge-base

# Database (PostgreSQL)
# Format: postgresql://user:password@hostname:port/database
DATABASE_URL=postgresql://user:password@db:5432/rfp_agent

# Security
SECRET_KEY=super-secret-development-key-change-in-production
